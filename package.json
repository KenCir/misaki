{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "misaki",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "tsc",
		"lint": "prettier --check . && eslint --ext .ts --format=pretty src",
		"deploy": "node dist/util/deploy.js",
		"deploy:guild": "node --env-file=.env dist/util/deployGuild.js",
		"format": "prettier --write . && eslint --ext .ts --fix --format=pretty src",
		"start": "node --env-file=.env dist/index.js",
		"dev": "NODE_ENV=development node --env-file=.env --enable-source-maps dist/index.js",
		"prepare": "husky"
	},
	"dependencies": {
		"@discordjs/core": "^2.5.0",
		"bufferutil": "^4.1.0",
		"discord.js": "^14.26.4",
		"openai": "^6.44.0",
		"pino": "^10.3.1",
		"zlib-sync": "^0.1.10",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@sapphire/ts-config": "^5.0.3",
		"@types/node": "^24.13.2",
		"eslint": "^10.6.0",
		"eslint-config-neon": "^0.5.4",
		"eslint-formatter-compact": "^9.0.1",
		"eslint-formatter-pretty": "^7.1.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"pino-pretty": "^13.1.3",
		"prettier": "^3.8.4",
		"typescript": "~6.0.3"
	},
	"engines": {
		"node": ">=22.12.0"
	}
}
